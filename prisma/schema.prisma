generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
}

enum SenderType {
  USER
  AI
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
}

enum NotificationType {
  REMINDER
  ALERT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String    @id @default(uuid())
  fullname      String
  email         String    @unique
  phone         String?   @unique
  password_hash String
  role          Role      @default(USER)
  status        Status    @default(ACTIVE)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  incomes       Income[]
  expenses      Expense[]
  savings       Savings[]
  goals         Goal[]
  chatSessions  ChatSession[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Income {
  id            String   @id @default(uuid())
  user_id       String
  amount        Decimal  @db.Decimal(10, 2)
  frequency     String   // e.g., Monthly, Weekly, One-time
  source        String   // e.g., Salary, Business, Freelance
  date_received DateTime
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Expense {
  id            String   @id @default(uuid())
  user_id       String
  category      String   // e.g., Food, Transport, Rent
  amount        Decimal  @db.Decimal(10, 2)
  description   String?
  expense_date  DateTime
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Savings {
  id            String   @id @default(uuid())
  user_id       String
  percentage    Int      // e.g., 20
  amount_saved  Decimal  @db.Decimal(10, 2)
  month         String   // e.g., 2024-05
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month])
}

model Goal {
  id             String   @id @default(uuid())
  user_id        String
  name           String   // e.g., Emergency fund
  target_amount  Decimal  @db.Decimal(10, 2)
  current_amount Decimal  @db.Decimal(10, 2) @default(0)
  deadline       DateTime?
  created_at     DateTime @default(now())

  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ChatSession {
  id         String   @id @default(uuid())
  user_id    String
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages   ChatMessage[]
}

model ChatMessage {
  id         String     @id @default(uuid())
  session_id String
  sender     SenderType
  content    String
  created_at DateTime   @default(now())

  session    ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String             @id @default(uuid())
  user_id    String
  channel    NotificationChannel
  type       NotificationType
  status     NotificationStatus @default(PENDING)
  sent_at    DateTime?
  created_at DateTime           @default(now())

  user       User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  action     String   // e.g., SUSPEND_USER, DELETE_USER
  resource   String   // e.g., User ID
  details    String?
  created_at DateTime @default(now())

  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
}
